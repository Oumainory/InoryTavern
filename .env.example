# InoryTavern 环境变量模板
# 复制本文件为 .env：cp .env.example .env
# 然后填入你自己的真实密钥（绝对不要把 .env 提交到 Git！）

# ===== 数据库 =====
# SQLite 本地文件（默认即可，开箱即用）
DATABASE_URL="file:./dev.db"

# ===== 兼容 OpenAI 格式的 API 中转 =====
# 例如 OpenAI / Azure / OneAPI / totalgpt 等任何兼容 /v1/chat/completions 的服务
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_API_KEY=""

# 默认模型：用于聊天/捏卡/语音的兜底值
# 也可在网页「设置」页为聊天、捏卡、TTS 分别独立指定
OPENAI_MODEL="gpt-4o-mini"

# ===== 可选：TTS 语音模型 =====
# 当「设置」页选 Kokoro 之外的 TTS 时，可在此兜底指定
# OPENAI_TTS_MODEL="tts-1"

# ===== 可选：Embedding 模型 =====
# 用于 RAG 长期记忆的向量化
# OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
